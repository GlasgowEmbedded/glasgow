	(text "Cycle +3.3V\non reset to \nget I2C peri-\npherals into \nclean state."
		(exclude_from_sim no)
		(at 73.66 148.59 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "0beed8d9-0dbd-483b-92c4-7861a99c78f2")
	)
	(text "Vfb = 0.6V\nV_hi = 5.5V\nV_lo = 0.9V\nV_mid = (V_hi-V_lo)/2 = 5.5V - 0.9V / 2 = 2.3V\nR1 = 68k, R2 = 24k\nI_margin = (V_out * (1 + MARGIN) - V_fb) / R1 - I_nominal\nMARGIN = 100% = 1\nI_nominal = V_mid / (R1 + R2) + I_fb\nWe ignore I_fb because it's 1nA typical (and we keep FBn floating)\nI_nominal = 2.3V / (68k + 24k) = 25µA\nI_margin = (2.3 * 2 - 0.6) / 68k - I_nominal = 33.8µA\nR3 = (V_dac - V_fb) / I_margin = 79.8k"
		(exclude_from_sim no)
		(at 217.17 54.61 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "0d9155a0-0bf6-4c90-88a0-2a9c79e136ac")
	)
	(text "might be a bit overkill\nthis keeps the ~{RESET}\nlow even below 1V"
		(exclude_from_sim no)
		(at 114.3 147.32 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "11a529be-7f1a-4dc4-b135-73c56ba37d28")
	)
