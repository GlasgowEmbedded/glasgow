	(text "Flash ~{CS} is controlled by the\nFPGA. Flash is held in reset by\ndefault, MCU can override the weak\npull-down."
		(exclude_from_sim no)
		(at 16.51 102.87 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "15bf2d96-2ea6-4dd8-a402-40464712fa73")
	)
	(text "Synchronization input/output accommodates multiple I/O standards: Vil=0.8V, Vih=2.0V.\n * Nominally, ~{SYNC} is open-drain and 3.3V, with weak internal pull-up.\n * Nevertheless, ~{SYNC} can be connected to 5V circuits directly.\n * ~{SYNC} may also be driven as push-pull to increase bandwidth.\n   Care must be taken to avoid contention. Nevertheless, two Glasgows \n   contending on ~{SYNC} will not exceed absolute maximum ratings.\n   A 47 ohm series resistor is recommended for other drivers."
		(exclude_from_sim no)
		(at 191.77 29.21 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "20ba6cff-56fc-4581-b0ba-6efe6b81fa7b")
	)
